{
  "name": "@urisocial/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for URI Social API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "urisocial",
    "social-media",
    "content-generation",
    "ai",
    "sdk",
    "typescript"
  ],
  "author": "URI Social <support@urisocial.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uri-social/urisocial-sdk",
    "directory": "packages/typescript-sdk"
  },
  "homepage": "https://github.com/uri-social/urisocial-sdk/tree/main/packages/typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/uri-social/urisocial-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
