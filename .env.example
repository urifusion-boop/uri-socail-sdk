# URI Social API Key
# Get your API key from: https://urisocial.com/dashboard/api-keys
URISOCIAL_API_KEY=your-api-key-here

# Optional: Custom API URL (defaults to https://api.urisocial.com)
# URISOCIAL_API_URL=https://api.urisocial.com

# Optional: Request timeout in milliseconds (defaults to 60000)
# URISOCIAL_TIMEOUT=60000
